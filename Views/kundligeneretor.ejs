<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>AstroSphere</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Poppins', sans-serif; overflow-x: hidden; }
    canvas { position: fixed; top: 0; left: 0; z-index: -1; }
  </style>
</head>

<body class="bg-black text-white">

<canvas id="stars"></canvas>

<nav class="flex justify-between items-center px-8 py-5">
  <h1 class="text-2xl font-bold text-purple-400">AstroSphere</h1>
  <button onclick="window.location.href='/dashboard'" class="bg-purple-600 px-4 py-2 rounded-full">Back to Dashboard</button>
  <div class="space-x-6 hidden md:block">
    <a href="#" class="hover:text-purple-400">Home</a>
    <a href="#" class="hover:text-purple-400">Horoscope</a>
    <a href="#" class="hover:text-purple-400">Zodiac</a>
    <a href="#" class="hover:text-purple-400">Contact</a>
  </div>
</nav>


<!-- 🔮 Kundli Generator -->
<section class="py-16 px-6 flex justify-center">
  <div class="bg-white/10 backdrop-blur-lg border border-purple-500 rounded-2xl p-8 w-full max-w-xl">
    <h2 class="text-2xl font-bold mb-6 text-center">Kundli Generator</h2>
    
    <form action="/kundli" method="POST">
    <input type="hidden" name="_method" value="POST">
    <div class="space-y-4">
      <input id="name" name="name" type="text" placeholder="Your Name" class="w-full p-3 rounded bg-black/40 border border-purple-400">
      <input id="dob" name="dob" type="date" placeholder="Your DOB" class="w-full p-3 rounded bg-black/40 border border-purple-400">
      <input id="time" name="time" type="time" placeholder="Your Birth time As 24hr" class="w-full p-3 rounded bg-black/40 border border-purple-400">
      <input id="place" name="place" type="text" placeholder="Birth Place" class="w-full p-3 rounded bg-black/40 border border-purple-400">

      <button type="button" onclick="generateKundli()" class="w-full bg-purple-600 hover:bg-purple-800 py-3 rounded">Generate Kundli</button>
    </div>
  </form>

    <!-- Result -->
    <div id="result" class="mt-6 text-center text-gray-300 hidden"></div>
  </div>
</section>

<section class="grid md:grid-cols-3 gap-8 px-8 py-16">
  <div class="bg-white/10 backdrop-blur-lg p-6 rounded-2xl border border-purple-500 hover:scale-105 transition">
    <h3 class="text-xl font-semibold mb-3">🌞 Daily Horoscope</h3>
    <p class="text-gray-300">Accurate predictions for your zodiac sign.</p>
  </div>
  <div class="bg-white/10 backdrop-blur-lg p-6 rounded-2xl border border-purple-500 hover:scale-105 transition">
    <h3 class="text-xl font-semibold mb-3">🌙 Moon Phases</h3>
    <p class="text-gray-300">Track lunar influence on life.</p>
  </div>
  <div class="bg-white/10 backdrop-blur-lg p-6 rounded-2xl border border-purple-500 hover:scale-105 transition">
    <h3 class="text-xl font-semibold mb-3">✨ Compatibility</h3>
    <p class="text-gray-300">Find your perfect match.</p>
  </div>
</section>

<footer class="text-center py-6 border-t border-purple-700">
  <p class="text-gray-400">© 2026 AstroSphere. All rights reserved.</p>
</footer>

<script>
// ⭐ Stars animation
const canvas = document.getElementById('stars');
const ctx = canvas.getContext('2d');
canvas.width = window.innerWidth;
canvas.height = window.innerHeight;
let stars = [];
for (let i = 0; i < 200; i++) {
  stars.push({ x: Math.random()*canvas.width, y: Math.random()*canvas.height, r: Math.random()*1.5, s: Math.random()*0.5 });
}
function draw(){
  ctx.clearRect(0,0,canvas.width,canvas.height);
  ctx.fillStyle='white';
  stars.forEach(star=>{
    ctx.beginPath(); ctx.arc(star.x, star.y, star.r, 0, Math.PI*2); ctx.fill();
    star.y += star.s;
    if(star.y>canvas.height){ star.y=0; star.x=Math.random()*canvas.width; }
  });
  requestAnimationFrame(draw);
}
window.addEventListener('mousemove', e=>{
  stars.forEach(star=>{ star.x += e.movementX*0.02; star.y += e.movementY*0.02; });
});
window.addEventListener('resize', ()=>{ canvas.width=window.innerWidth; canvas.height=window.innerHeight; });
draw();

// 🔮 Simple Kundli logic (demo only)
function generateKundli(){
  const name = document.getElementById('name').value;
  const dob = new Date(document.getElementById('dob').value);
  const month = dob.getMonth()+1;

  const zodiac = ["Capricorn","Aquarius","Pisces","Aries","Taurus","Gemini","Cancer","Leo","Virgo","Libra","Scorpio","Sagittarius"][month-1];

  const result = document.getElementById('result');
  result.classList.remove('hidden');
  result.innerHTML = `✨ <b>${name}</b>, your zodiac sign is <b>${zodiac}</b>.<br>\n  This is a basic Kundli preview. Full chart requires astrology API.`;
}
</script>

</body>
</html>
