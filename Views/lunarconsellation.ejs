  },
  "Purva Ashadha": {
    trait: "Confident, expressive",
    career: "Public speaking",
    nature: "Bold"
  },
  "Uttara Ashadha": {
    trait: "Disciplined, strong",
    career: "Government roles",
    nature: "Leader"
  },
  Shravana: {
    trait: "Listener, wise",
    career: "Teaching",
    nature: "Calm"
  },
  Dhanishta: {
    trait: "Wealth, rhythm",
    career: "Music, finance",
    nature: "Energetic"
  },
  Shatabhisha: {
    trait: "Healing, secretive",
    career: "Medicine",
    nature: "Private"
  },
  "Purva Bhadrapada": {
    trait: "Spiritual, intense",
    career: "Philosophy",
    nature: "Deep thinker"
  },
  "Uttara Bhadrapada": {
    trait: "Calm, stable",
    career: "Teaching",
    nature: "Peaceful"
  },
  Revati: {
    trait: "Kind, spiritual",
    career: "Helping roles",
    nature: "Gentle"
  }
};

// ⚠️ Approx logic (demo)
function calculateNakshatra(){

  const name = document.getElementById("name").value;
  const dob = document.getElementById("dob").value;

  if(!name || !dob){
    alert("Please fill all details");
    return;
  }

  const date = new Date(dob);
  const dayOfYear = Math.floor(
    (date - new Date(date.getFullYear(), 0, 0)) / 86400000
  );

  const index = dayOfYear % 27;
  const nak = nakshatras[index];
  const data = nakshatraDetails[nak];

  document.getElementById("result").innerHTML = `
    <div class="bg-purple-800/30 p-6 rounded-xl mt-4">
      <h2 class="text-2xl font-bold mb-2">${name}, your Nakshatra is</h2>
      <h1 class="text-3xl text-purple-400 mb-4">${nak}</h1>

      🌟 <b>Traits:</b> ${data.trait} <br><br>
      💼 <b>Career:</b> ${data.career} <br><br>
      🧠 <b>Nature:</b> ${data.nature} <br><br>

      <p class="text-sm text-gray-400 mt-4">
      (Approx result — real Nakshatra requires precise moon calculation)
      </p>
    </div>
  `;
}

</script>

</body>
</html>
